generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum ProductStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum VariantStatus {
  ACTIVE
  OUT_OF_STOCK
  ARCHIVED
}

enum OrderStatus {
  NEW
  CONFIRMED
  CANCELLED
  COMPLETED
}

model Category {
  id          String    @id @default(cuid())
  slug        String    @unique
  name        String
  description String?
  products    Product[]
}

model Product {
  id               String         @id @default(cuid())
  slug             String         @unique
  title            String
  description      String
  shortDescription String
  status           ProductStatus  @default(ACTIVE)
  composition      String
  certification    String
  popularRank      Int            @default(0)
  previewRank      Int            @default(0)
  categoryId       String
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  category         Category       @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  colors           ProductColor[]
  images           ProductImage[]

  @@index([categoryId])
  @@index([popularRank])
  @@index([previewRank])
}

model ProductColor {
  id         String           @id @default(cuid())
  productId  String
  slug       String
  name       String
  sortOrder  Int              @default(0)
  product    Product          @relation(fields: [productId], references: [id], onDelete: Cascade)
  variants   ProductVariant[]
  images     ProductImage[]

  @@unique([productId, slug])
  @@index([productId, sortOrder])
}

model ProductVariant {
  id             String        @id @default(cuid())
  productColorId String
  size           String
  sku            String        @unique
  price          Decimal       @db.Decimal(10, 2)
  oldPrice       Decimal?      @db.Decimal(10, 2)
  stock          Int           @default(0)
  status         VariantStatus @default(ACTIVE)
  productColor   ProductColor  @relation(fields: [productColorId], references: [id], onDelete: Cascade)

  @@unique([productColorId, size])
  @@index([productColorId])
}

model ProductImage {
  id             String        @id @default(cuid())
  productId      String
  productColorId String?
  path           String
  alt            String
  sortOrder      Int           @default(0)
  isMain         Boolean       @default(false)
  product        Product       @relation(fields: [productId], references: [id], onDelete: Cascade)
  productColor   ProductColor? @relation(fields: [productColorId], references: [id], onDelete: SetNull)

  @@index([productId, sortOrder])
  @@index([productColorId, sortOrder])
}

model Order {
  id                  String       @id @default(cuid())
  orderNumber         String       @unique
  customerName        String
  phone               String
  city                String
  deliveryMethod      String
  deliveryAddress     String
  comment             String?
  subtotal            Decimal      @db.Decimal(10, 2)
  deliveryPrice       Decimal      @db.Decimal(10, 2)
  total               Decimal      @db.Decimal(10, 2)
  freeDeliveryApplied Boolean      @default(false)
  status              OrderStatus  @default(NEW)
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt
  items               OrderItem[]

  @@index([createdAt])
}

model OrderItem {
  id                   String   @id @default(cuid())
  orderId              String
  productId            String?
  productColorId       String?
  productVariantId     String?
  productTitleSnapshot String
  colorNameSnapshot    String?
  sizeSnapshot         String?
  skuSnapshot          String?
  quantity             Int
  unitPrice            Decimal  @db.Decimal(10, 2)
  lineTotal            Decimal  @db.Decimal(10, 2)
  order                Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
}
